# ---------------------------------------------------------------------------
# Stakemate — environment
# Copy to .env.local for local dev, or set in Vercel project settings.
# ---------------------------------------------------------------------------

# Shared Redis with the puzzle app (enables connect-once via the circles:lichess
# key, and stores cw:* challenge data). Local dev falls back to a JSON file
# (.data/store.json) when unset.
REDIS_URL=

# The escrow org Safe ("Stakemate Escrow") that holds stakes and pays winners.
ESCROW_ORG_ADDRESS=

# The EOA that signs for the escrow Safe (a Safe owner, threshold 1). It only
# signs — never holds funds. Must be funded with xDAI for gas. SERVER-ONLY.
ESCROW_PRIVATE_KEY=0x...

# Optional Lichess app token — only raises open-challenge rate limits.
LICHESS_API_TOKEN=

# Minimum stake, whole gCRC (client + server). Optional, default 1.
NEXT_PUBLIC_MIN_STAKE_CRC=1
